---
interface Props {
  name: string;
  type: string;
  description: string;
  objective: string;
  approach: string[];
  deliverables: string[];
  tags: string[];
  palette: string;
}

const { name, type, description, objective, approach, deliverables, tags, palette } = Astro.props;
---

<article class="card overflow-hidden hover:-translate-y-1">
  <div class={`relative h-52 ${palette}`}>
    <div class="absolute left-6 top-6 h-24 w-20 rounded-lg bg-white/80 p-3 shadow-soft dark:bg-night/75">
      <div class="mb-2 h-2 w-12 rounded-full bg-ink/20 dark:bg-white/20"></div>
      <div class="h-12 rounded-md bg-coral/70"></div>
      <div class="mt-2 h-2 w-10 rounded-full bg-ink/20 dark:bg-white/20"></div>
    </div>
    <div class="absolute bottom-6 right-6 h-32 w-24 rounded-[1.25rem] border-[6px] border-ink bg-white shadow-soft dark:border-night dark:bg-nightcard">
      <div class="mx-auto mt-2 h-1 w-8 rounded-full bg-ink/25 dark:bg-white/25"></div>
      <div class="m-3 h-16 rounded-md bg-sage/80"></div>
      <div class="mx-3 h-2 rounded-full bg-ink/20 dark:bg-white/20"></div>
      <div class="mx-3 mt-2 h-2 w-10 rounded-full bg-ink/20 dark:bg-white/20"></div>
    </div>
    <div class="absolute left-28 top-20 h-16 w-16 rounded-full bg-white/70 mix-blend-soft-light"></div>
  </div>

  <div class="p-6">
    <p class="text-sm font-bold text-coral">{type}</p>
    <h3 class="mt-2 font-display text-2xl font-bold">{name}</h3>
    <p class="mt-4 leading-7 text-muted dark:text-nighttext/72">{description}</p>
    <p class="mt-4 rounded-lg bg-ink/[0.04] p-4 text-sm font-semibold leading-6 text-ink dark:bg-white/[0.06] dark:text-nighttext">
      Obiettivo: {objective}
    </p>
    <div class="mt-5 rounded-lg border border-ink/10 bg-white/55 p-4 dark:border-white/10 dark:bg-white/[0.04]">
      <p class="text-sm font-bold">Cosa farei</p>
      <ul class="mt-3 grid gap-2 text-sm leading-6 text-muted dark:text-nighttext/72">
        {approach.map((item) => <li>• {item}</li>)}
      </ul>
    </div>
    <div class="mt-5">
      <p class="text-sm font-bold">Deliverable concept</p>
      <ul class="mt-3 grid gap-2 text-sm text-muted dark:text-nighttext/72">
        {deliverables.map((item) => <li>• {item}</li>)}
      </ul>
    </div>
    <div class="mt-5 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-ink/[0.06] px-3 py-1 text-xs font-bold text-muted dark:bg-white/[0.08] dark:text-nighttext/72">{tag}</span>
      ))}
    </div>
  </div>
</article>
