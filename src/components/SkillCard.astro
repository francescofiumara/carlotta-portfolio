---
interface Props {
  title: string;
  text: string;
  tone: 'coral' | 'apricot' | 'lilac' | 'sage';
}

const { title, text, tone } = Astro.props;
const tones = {
  coral: 'bg-coral/10 text-coral',
  apricot: 'bg-apricot/25 text-ink dark:text-nighttext',
  lilac: 'bg-lilac/30 text-ink dark:text-nighttext',
  sage: 'bg-sage/30 text-ink dark:text-nighttext',
};
---

<article class="card p-6 hover:-translate-y-1">
  <div class={`mb-5 flex h-11 w-11 items-center justify-center rounded-full ${tones[tone]}`} aria-hidden="true">
    <span class="h-3 w-3 rounded-full bg-current"></span>
  </div>
  <h3 class="font-display text-xl font-bold">{title}</h3>
  <p class="mt-3 leading-7 text-muted dark:text-nighttext/72">{text}</p>
</article>
