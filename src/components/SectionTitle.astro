---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const { eyebrow, title, text } = Astro.props;
---

<div class="mx-auto mb-10 max-w-3xl text-center sm:mb-12">
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="font-display text-3xl font-bold leading-tight sm:text-4xl">{title}</h2>
  {text && <p class="mt-4 text-base leading-7 text-muted dark:text-nighttext/72">{text}</p>}
</div>
